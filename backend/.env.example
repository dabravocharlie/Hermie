# --- Hermie backend environment variables ---
# Copy this file to ".env" for local development and fill in real values.
# On Render, set these in the service's Environment tab (do NOT commit .env).

# Postgres connection string (from Render Postgres "Internal/External Database URL")
DATABASE_URL=

# Clerk secret key (Clerk dashboard > API Keys > Secret keys). Starts with sk_
CLERK_SECRET_KEY=

# Clerk publishable key (same page; starts with pk_). The backend uses it too.
CLERK_PUBLISHABLE_KEY=

# Your frontend URL(s), comma-separated. Include localhost for local dev.
# Example: https://hermie.vercel.app,http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173

# Port (Render sets this automatically; 3001 is fine locally)
PORT=3001

# Finnhub API key for live stock prices + company news (free tier at finnhub.io).
# Without this, the Portfolio tab still works but shows holdings without prices.
FINNHUB_API_KEY=

# Anthropic API key powers the Hermie assistant (console.anthropic.com).
# Without it, the app runs fine but Hermie's chat is switched off.
ANTHROPIC_API_KEY=

# Optional: override the model Hermie uses (defaults to a sensible choice).
# HERMIE_MODEL=claude-sonnet-4-6
