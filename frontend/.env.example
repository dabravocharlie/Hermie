# --- Hermie frontend environment variables ---
# Copy this file to ".env" for local development and fill in real values.
# On Vercel, set these in Project Settings > Environment Variables.
# NOTE: Vite only exposes variables that start with VITE_.

# Clerk publishable key (Clerk dashboard > API Keys). Starts with pk_
VITE_CLERK_PUBLISHABLE_KEY=

# Your backend API URL.
# Local: http://localhost:3001
# Production: https://your-backend.onrender.com
VITE_API_URL=http://localhost:3001
