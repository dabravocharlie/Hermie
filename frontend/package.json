    "cap:ios": "vite build && npx cap sync ios && npx cap open ios"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.0"
  }
}
